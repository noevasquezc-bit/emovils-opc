{
  "name": "Emovils — Publicador de Contenido Orgánico",
  "description": "El agente de contenido genera y prepara piezas para publicar en Instagram/Facebook cada día",
  "nodes": [
    {
      "id": "trigger_content",
      "name": "Trigger 9:00 AM (Publicación)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [100, 300],
      "parameters": {
        "rule": {
          "interval": [{"field": "cronExpression", "expression": "0 9 * * *"}]
        }
      }
    },
    {
      "id": "get_day_of_week",
      "name": "Obtener Día de la Semana",
      "type": "n8n-nodes-base.code",
      "position": [300, 300],
      "parameters": {
        "language": "python",
        "code": "from datetime import datetime\n\nhoy = datetime.now()\ndias = ['lunes', 'martes', 'miercoles', 'jueves', 'viernes', 'sabado', 'domingo']\ndia = dias[hoy.weekday()]\n\nangulos = {\n    'lunes': 'seguridad',\n    'martes': 'familia',\n    'miercoles': 'ejecutivo',\n    'jueves': 'precio_claro',\n    'viernes': 'experiencia_cliente',\n    'sabado': 'testimonio',\n    'domingo': 'reactivacion'\n}\n\nreturn [{\n    'dia': dia,\n    'angulo': angulos.get(dia, 'seguridad'),\n    'fecha': hoy.strftime('%d/%m/%Y')\n}]"
      }
    },
    {
      "id": "generate_content",
      "name": "Agente Contenido IA",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 300],
      "parameters": {
        "url": "={{ $env.BACKEND_URL }}/agent/contenido/post",
        "method": "POST",
        "body": {
          "angulo": "={{ $json.angulo }}",
          "dia": "={{ $json.dia }}",
          "producto": "airport"
        }
      }
    },
    {
      "id": "save_to_airtable",
      "name": "Guardar en Airtable (Cola de Publicación)",
      "type": "n8n-nodes-base.airtable",
      "position": [700, 300],
      "parameters": {
        "operation": "create",
        "baseId": "={{ $env.AIRTABLE_BASE_ID }}",
        "tableId": "Contenido",
        "fields": {
          "Fecha": "={{ $('Obtener Día de la Semana').item.json.fecha }}",
          "Dia": "={{ $('Obtener Día de la Semana').item.json.dia }}",
          "Angulo": "={{ $('Obtener Día de la Semana').item.json.angulo }}",
          "Texto_Post": "={{ $('Agente Contenido IA').item.json.content }}",
          "Status": "listo_para_publicar",
          "Producto": "airport",
          "Plataforma": "instagram_facebook"
        }
      }
    },
    {
      "id": "notify_owner_content",
      "name": "Enviar Contenido al Dueño",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 300],
      "parameters": {
        "url": "={{ $env.WHATSAPP_API_URL }}/messages",
        "method": "POST",
        "headers": {"D360-API-KEY": "={{ $env.WHATSAPP_API_KEY }}"},
        "body": {
          "messaging_product": "whatsapp",
          "to": "={{ $env.OWNER_WHATSAPP }}",
          "type": "text",
          "text": {
            "body": "=📱 CONTENIDO DEL DÍA LISTO\n\nDía: {{ $('Obtener Día de la Semana').item.json.dia }}\nÁngulo: {{ $('Obtener Día de la Semana').item.json.angulo }}\n\n{{ $('Agente Contenido IA').item.json.content }}\n\n---\nRevisa y publica cuando lo veas bien."
          }
        }
      }
    }
  ],
  "connections": {
    "trigger_content": {"main": [["get_day_of_week"]]},
    "get_day_of_week": {"main": [["generate_content"]]},
    "generate_content": {"main": [["save_to_airtable"]]},
    "save_to_airtable": {"main": [["notify_owner_content"]]}
  },
  "settings": {"timezone": "America/Santo_Domingo"}
}
