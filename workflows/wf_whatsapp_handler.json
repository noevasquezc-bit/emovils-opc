{
  "name": "Emovils — WhatsApp Handler (Vendedor IA)",
  "description": "Recibe mensajes entrantes de WhatsApp y activa el agente vendedor",
  "nodes": [
    {
      "id": "webhook_wa",
      "name": "Webhook WhatsApp",
      "type": "n8n-nodes-base.webhook",
      "position": [100, 300],
      "parameters": {
        "path": "whatsapp-webhook",
        "httpMethod": "POST",
        "responseMode": "onReceived"
      }
    },
    {
      "id": "verify_webhook",
      "name": "Verificar Token Meta",
      "type": "n8n-nodes-base.code",
      "position": [300, 300],
      "parameters": {
        "language": "python",
        "code": "# Verificación de webhook de Meta\nimport json\n\npayload = $input.body\n\n# Verificación inicial de Meta (GET)\nif $input.method == 'GET':\n    verify_token = $env.WHATSAPP_VERIFY_TOKEN\n    hub_challenge = $input.query.get('hub.challenge')\n    hub_token = $input.query.get('hub.verify_token')\n    if hub_token == verify_token:\n        return [{'challenge': hub_challenge}]\n    raise ValueError('Token inválido')\n\n# Mensaje real (POST)\nreturn [{'payload': payload, 'is_message': True}]"
      }
    },
    {
      "id": "extract_message",
      "name": "Extraer Mensaje",
      "type": "n8n-nodes-base.code",
      "position": [500, 300],
      "parameters": {
        "language": "python",
        "code": "payload = $input.item.json.payload\n\ntry:\n    entry = payload['entry'][0]\n    changes = entry['changes'][0]\n    value = changes['value']\n    messages = value.get('messages', [])\n    \n    if not messages:\n        return [{'skip': True}]\n    \n    msg = messages[0]\n    contact = value.get('contacts', [{}])[0]\n    \n    return [{\n        'from_number': msg['from'],\n        'message_text': msg.get('text', {}).get('body', ''),\n        'message_type': msg['type'],\n        'message_id': msg['id'],\n        'timestamp': msg['timestamp'],\n        'contact_name': contact.get('profile', {}).get('name', 'Sin nombre')\n    }]\nexcept Exception as e:\n    return [{'error': str(e), 'skip': True}]"
      }
    },
    {
      "id": "check_lead_exists",
      "name": "Buscar Lead en Airtable",
      "type": "n8n-nodes-base.airtable",
      "position": [700, 300],
      "parameters": {
        "operation": "list",
        "baseId": "={{ $env.AIRTABLE_BASE_ID }}",
        "tableId": "Leads",
        "filterByFormula": "={WhatsApp} = '{{ $json.from_number }}'"
      }
    },
    {
      "id": "create_or_update_lead",
      "name": "Crear/Actualizar Lead",
      "type": "n8n-nodes-base.airtable",
      "position": [900, 300],
      "parameters": {
        "operation": "upsert",
        "baseId": "={{ $env.AIRTABLE_BASE_ID }}",
        "tableId": "Leads",
        "fields": {
          "WhatsApp": "={{ $('Extraer Mensaje').item.json.from_number }}",
          "Nombre": "={{ $('Extraer Mensaje').item.json.contact_name }}",
          "Status": "nuevo",
          "Canal_Origen": "whatsapp_inbound",
          "Producto": "airport",
          "Fecha_Contacto": "={{ $now }}"
        }
      }
    },
    {
      "id": "call_vendedor_agent",
      "name": "Agente Vendedor IA",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1100, 300],
      "parameters": {
        "url": "={{ $env.BACKEND_URL }}/agent/vendedor/respond",
        "method": "POST",
        "body": {
          "wa_number": "={{ $('Extraer Mensaje').item.json.from_number }}",
          "message": "={{ $('Extraer Mensaje').item.json.message_text }}",
          "contact_name": "={{ $('Extraer Mensaje').item.json.contact_name }}"
        }
      }
    },
    {
      "id": "send_wa_response",
      "name": "Enviar Respuesta WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1300, 300],
      "parameters": {
        "url": "={{ $env.WHATSAPP_API_URL }}/messages",
        "method": "POST",
        "headers": {
          "D360-API-KEY": "={{ $env.WHATSAPP_API_KEY }}"
        },
        "body": {
          "messaging_product": "whatsapp",
          "to": "={{ $('Extraer Mensaje').item.json.from_number }}",
          "type": "text",
          "text": {
            "body": "={{ $('Agente Vendedor IA').item.json.response }}"
          }
        }
      }
    }
  ],
  "connections": {
    "webhook_wa": {"main": [["verify_webhook"]]},
    "verify_webhook": {"main": [["extract_message"]]},
    "extract_message": {"main": [["check_lead_exists"]]},
    "check_lead_exists": {"main": [["create_or_update_lead"]]},
    "create_or_update_lead": {"main": [["call_vendedor_agent"]]},
    "call_vendedor_agent": {"main": [["send_wa_response"]]}
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "America/Santo_Domingo"
  }
}
