BASE_URL = os.getenv("BASE_URL", "https://emovils-opc-production.up.railway.app")


def _generar_qr_b64(url: str) -> str:
    """Genera un QR como base64 PNG para embeber en HTML."""
    try:
        qr = qrcode.QRCode(version=1, box_size=8, border=2)
        qr.add_data(url)
        qr.make(fit=True)
        img = qr.make_image(fill_color="#1a1a2e", back_color="white")
        buf = io.BytesIO()
        img.save(buf, format="PNG")
        return base64.b64encode(buf.getvalue()).decode()
    except Exception as e:
        logger.warning("Error generando QR: %s", e)
        return ""


def _html(contenido: str) -> object:
    resp = make_response(contenido)
    resp.headers["Content-Type"] = "text/html; charset=utf-8"
    return resp


