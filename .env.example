# ═══════════════════════════════════════════════════════════════
# EMOVILS OPC — Variables de Entorno
# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env a Git
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# NEGOCIO
# ─────────────────────────────────────────────
BUSINESS_WHATSAPP_NUMBER=+1809XXXXXXX
BUSINESS_EMAIL=hola@emovils.com
PILOT_START_DATE=2026-05-10

# ─────────────────────────────────────────────
# DUEÑO (para notificaciones diarias)
# ─────────────────────────────────────────────
OWNER_WHATSAPP=+1809XXXXXXX
OWNER_EMAIL=noe@emovils.com

# ─────────────────────────────────────────────
# ANTHROPIC (Claude IA)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# WHATSAPP BUSINESS API (360Dialog)
# Alternativas: Meta Cloud API, Twilio
# ─────────────────────────────────────────────
WHATSAPP_API_URL=https://waba.360dialog.io/v1
WHATSAPP_API_KEY=YOUR_360DIALOG_API_KEY
WHATSAPP_PHONE_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_VERIFY_TOKEN=emovils_verify_2026

# ─────────────────────────────────────────────
# META ADS (Facebook / Instagram)
# ─────────────────────────────────────────────
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN
META_AD_ACCOUNT_ID=act_XXXXXXXXXX
META_APP_ID=YOUR_APP_ID
META_APP_SECRET=YOUR_APP_SECRET
META_PIXEL_ID=YOUR_PIXEL_ID
META_CAMPAIGN_ID=YOUR_MAIN_CAMPAIGN_ID

# ─────────────────────────────────────────────
# AIRTABLE (CRM + Dashboard)
# ─────────────────────────────────────────────
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX  # Tu PAT token de Airtable
AIRTABLE_BASE_ID=app9CGq0LCsEk09r7  # Base "Emovils OPC" — CREADA ✅
AIRTABLE_LEADS_TABLE=Leads
AIRTABLE_BOOKINGS_TABLE=Bookings
AIRTABLE_CONVERSATIONS_TABLE=Conversations
AIRTABLE_POSTS_TABLE=Posts
AIRTABLE_CAMPAIGNS_TABLE=Campaigns
AIRTABLE_METRICS_TABLE=Daily_Metrics

# ─────────────────────────────────────────────
# STRIPE (Pagos)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────
# GOOGLE MAPS
# ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaSy...

# ─────────────────────────────────────────────
# N8N CLOUD
# ─────────────────────────────────────────────
N8N_BASE_URL=https://app.n8n.cloud
N8N_API_KEY=YOUR_N8N_API_KEY

# ─────────────────────────────────────────────
# SERVIDOR BACKEND
# ─────────────────────────────────────────────
BACKEND_URL=https://your-backend.railway.app
PORT=5000
LOG_LEVEL=INFO
LOG_FILE=logs/emovils.log

# ═══════════════════════════════════════════════════════════════
# REGLA DE ORO: CPA MÁXIMO = $6 USD — INVIOLABLE
# Si CPA > $8 → PAUSA AUTOMÁTICA
# Presupuesto diario: $4/día (máximo $100 en 21 días)
# ═══════════════════════════════════════════════════════════════
