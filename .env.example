# ═══════════════════════════════════════════════════════════════
# EMOVILS OPC — Variables de Entorno
# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env a Git
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# NEGOCIO
# ─────────────────────────────────────────────
BUSINESS_WHATSAPP_NUMBER=+1809XXXXXXX
BUSINESS_EMAIL=hola@emovils.com
PILOT_START_DATE=2026-05-10

# ─────────────────────────────────────────────
# DUEÑO (para notificaciones diarias)
# ─────────────────────────────────────────────
OWNER_WHATSAPP=+1809XXXXXXX
OWNER_EMAIL=noe@emovils.com

# ─────────────────────────────────────────────
# ANTHROPIC (Claude IA)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# WHATSAPP BUSINESS API (360Dialog)
# Alternativas: Meta Cloud API, Twilio
# ─────────────────────────────────────────────
WHATSAPP_API_URL=https://waba.360dialog.io/v1
WHATSAPP_API_KEY=YOUR_360DIALOG_API_KEY
WHATSAPP_PHONE_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_VERIFY_TOKEN=emovils_verify_2026

# ─────────────────────────────────────────────
# META ADS (Facebook / Instagram)
# ─────────────────────────────────────────────
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN
META_AD_ACCOUNT_ID=act_XXXXXXXXXX
META_APP_ID=YOUR_APP_ID
META_APP_SECRET=YOUR_APP_SECRET
META_PIXEL_ID=YOUR_PIXEL_ID
META_CAMPAIGN_ID=YOUR_MAIN_CAMPAIGN_ID
# Publicación orgánica (agente_social.publicar_post)
META_PAGE_ID=YOUR_FACEBOOK_PAGE_ID
META_IG_USER_ID=YOUR_INSTAGRAM_BUSINESS_USER_ID

# ─────────────────────────────────────────────
# PROSPECCIÓN B2B (agente_prospector)
# Apify: scraping Google Maps · Apollo: enriquecimiento de contactos
# Sin tokens el agente funciona en modo mock con el catálogo semilla RD
# ─────────────────────────────────────────────
APIFY_API_TOKEN=apify_api_XXXXXXXXXX
APIFY_ACTOR_ID=compass~crawler-google-places
APOLLO_API_KEY=YOUR_APOLLO_API_KEY

# ─────────────────────────────────────────────
# EMAIL CORPORATIVO @emovils.com (agente_email_router)
# Envío: Resend API (primario) con fallback SMTP
# Sin credenciales el router omite envíos con log claro (modo mock)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXX
RESEND_FROM_DOMAIN=emovils.com
EMAIL_SMTP_HOST=mail.emovils.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURITY=SSL  # SSL (465) o STARTTLS (587)
EMAIL_SMTP_USER=info@emovils.com
EMAIL_SMTP_PASS=YOUR_SMTP_PASSWORD
EMAIL_IMAP_HOST=mail.emovils.com
EMAIL_IMAP_PORT=993

# ─────────────────────────────────────────────
# ELEVENLABS (voz dominicana de Monserrat)
# Requiere AMBAS variables; sin ellas cae a gTTS (gratis)
# ─────────────────────────────────────────────
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_VOICE_ID=YOUR_CLONED_DOMINICAN_VOICE_ID
ELEVENLABS_MODEL=eleven_multilingual_v2

# ─────────────────────────────────────────────
# FACTURACIÓN NCF DGII (sistema_ncf)
# ─────────────────────────────────────────────
# Vigencia de las secuencias autorizadas por DGII
NCF_FECHA_VENCIMIENTO=2026-12-31
# Rangos autorizados por tipo (cantidad de comprobantes)
NCF_RANGO_B01=1000
NCF_RANGO_B02=5000
NCF_RANGO_B14=200
NCF_RANGO_B15=100
NCF_RANGO_B04=100

# ─────────────────────────────────────────────
# AIRTABLE (CRM + Dashboard)
# ─────────────────────────────────────────────
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX  # Tu PAT token de Airtable
AIRTABLE_BASE_ID=app9CGq0LCsEk09r7  # Base "Emovils OPC" — CREADA ✅
AIRTABLE_LEADS_TABLE=Leads
AIRTABLE_BOOKINGS_TABLE=Bookings
AIRTABLE_CONVERSATIONS_TABLE=Conversations
AIRTABLE_POSTS_TABLE=Posts
AIRTABLE_CAMPAIGNS_TABLE=Campaigns
AIRTABLE_METRICS_TABLE=Daily_Metrics

# ─────────────────────────────────────────────
# PAYPAL (Pagos — el método principal en RD)
# ─────────────────────────────────────────────
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=sandbox  # "sandbox" o "live"
# Tasa de cambio para los links de pago (RD$ por 1 USD)
TASA_RD_POR_USD=60

# ─────────────────────────────────────────────
# STRIPE (Pagos — opcional, no usado en RD)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────
# OPENAI (Whisper + TTS de Monserrat)
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# QR.IO (códigos QR de recogida)
# ─────────────────────────────────────────────
QRIO_API_KEY=YOUR_QRIO_API_KEY

# ─────────────────────────────────────────────
# GOOGLE MAPS (cotización con distancia real;
# sin esta clave se usa el tarifario fijo)
# ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaSy...

# ─────────────────────────────────────────────
# N8N CLOUD
# ─────────────────────────────────────────────
N8N_BASE_URL=https://app.n8n.cloud
N8N_API_KEY=YOUR_N8N_API_KEY

# ─────────────────────────────────────────────
# SERVIDOR BACKEND
# ─────────────────────────────────────────────
BACKEND_URL=https://your-backend.railway.app
PORT=5000
LOG_LEVEL=INFO
LOG_FILE=logs/emovils.log

# ─────────────────────────────────────────────
# SCHEDULER (opc/scheduler.py — reportes 7:15, follow-ups,
# quincena, alertas documentos, plan social, safeguard CPA)
# 1 = activado (default). Debe correr en UN SOLO proceso:
# el Procfile usa gunicorn --workers 1 --threads 16 por esto.
# Si escalas workers en Railway, pon 0 aquí y corre un
# servicio worker aparte con ENABLE_SCHEDULER=1.
# ─────────────────────────────────────────────
ENABLE_SCHEDULER=1

# ═══════════════════════════════════════════════════════════════
# REGLA DE ORO: CPA MÁXIMO = $6 USD — INVIOLABLE
# Si CPA > $8 → PAUSA AUTOMÁTICA
# Presupuesto diario: $4/día (máximo $100 en 21 días)
# ═══════════════════════════════════════════════════════════════
